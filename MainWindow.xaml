<Window x:Class="SteamVault.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SteamVault.Views"
        Title="SteamVault" Height="780" Width="1160"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackground}"
        Foreground="{StaticResource Text}"
        MinWidth="900" MinHeight="600">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" /> <!-- Custom Title Bar -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="{StaticResource SidebarBackground}">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0">
                    <!-- Logo/Brand -->
                    <TextBlock Text="⚡" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="STEAMVAULT" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"
                               Foreground="{StaticResource MutedText}"/>
                     <TextBlock Text="v2.5.0" FontSize="10" Foreground="{StaticResource DimText}" 
                               VerticalAlignment="Center" Margin="8,2,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Click="Minimize_Click" Style="{StaticResource TitleBarMinimizeButton}" />
                    <Button x:Name="CloseButton" Click="Close_Click" Style="{StaticResource TitleBarCloseButton}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" /> <!-- Sidebar -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" x:Name="SidebarPanel">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0E0E18" Offset="0"/>
                        <GradientStop Color="#0A0A14" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Nav Items -->
                    <StackPanel Grid.Row="0" Margin="0,20,0,0">
                        <TextBlock Text="MENU" FontSize="10" FontWeight="Bold" Foreground="{StaticResource DimText}"
                                   Margin="28,0,0,12"/>
                        <RadioButton Content="🏠  Dashboard" Command="{Binding NavigateDashboardCommand}" 
                                     IsChecked="{Binding IsDashboardActive, Mode=OneWay}" GroupName="SidebarGroup" Style="{StaticResource SidebarNavButton}" />
                        <RadioButton Content="🔍  Discover" Command="{Binding NavigateDiscoverCommand}" 
                                     IsChecked="{Binding IsDiscoverActive, Mode=OneWay}" GroupName="SidebarGroup" Style="{StaticResource SidebarNavButton}" />
                        <RadioButton Content="🎮  My Games" Command="{Binding NavigateMyGamesCommand}" 
                                     IsChecked="{Binding IsMyGamesActive, Mode=OneWay}" GroupName="SidebarGroup" Style="{StaticResource SidebarNavButton}" />
                        <RadioButton Content="🌐  Online" Command="{Binding NavigateOnlineCommand}" 
                                     IsChecked="{Binding IsOnlineActive, Mode=OneWay}" GroupName="SidebarGroup" Style="{StaticResource SidebarNavButton}" />
                        <RadioButton Content="⚙  Settings" Command="{Binding NavigateSettingsCommand}" 
                                     IsChecked="{Binding IsSettingsActive, Mode=OneWay}" GroupName="SidebarGroup" Style="{StaticResource SidebarNavButton}" />
                    </StackPanel>

                    <!-- Bottom Stats -->
                    <Border Grid.Row="1" Margin="16,0,16,20" Padding="16,14" CornerRadius="12"
                            Background="#12121E">
                        <StackPanel>
                            <TextBlock x:Name="GameCountText" FontSize="12" 
                                       FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding AutoUpdateStatus}" FontSize="11" 
                                       Foreground="{StaticResource DimText}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Accent line between sidebar and content -->
            <Border Grid.Column="0" HorizontalAlignment="Right" Width="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1E1E30" Offset="0"/>
                        <GradientStop Color="#2A1A4E" Offset="0.5"/>
                        <GradientStop Color="#1E1E30" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Discord Button (bottom-right, always visible) -->
            <Button x:Name="DiscordButton" Click="Discord_Click"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Width="48" Height="48" Margin="0,0,20,20"
                    Panel.ZIndex="100" Cursor="Hand"
                    ToolTip="Join our Discord for game requests &amp; support">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="DiscordCircle" Background="#5865F2" CornerRadius="24" 
                                BorderBrush="#5865F2" BorderThickness="0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Image Source="Discord.png" Width="26" Height="26" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DiscordCircle" Property="Background" Value="#4752C4"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="DiscordCircle" 
                                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                           To="1.1" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="DiscordCircle" 
                                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                           To="1.1" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="DiscordCircle" 
                                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                           To="1" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="DiscordCircle" 
                                                           Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                           To="1" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="DiscordCircle" Property="Background" Value="#3C45A5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Main Content Area with fade transition -->
            <ContentControl Grid.Column="1" x:Name="MainContentHost" Content="{Binding}" Opacity="1">
                <ContentControl.RenderTransform>
                    <TranslateTransform X="0"/>
                </ContentControl.RenderTransform>
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type viewmodels:InstallationViewModel}" xmlns:viewmodels="clr-namespace:SteamVault.ViewModels">
                        <views:InstallationView />
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:MainViewModel}" xmlns:viewmodels="clr-namespace:SteamVault.ViewModels">
                        <ContentControl Content="{Binding CurrentView}">
                            <ContentControl.Resources>
                                <DataTemplate DataType="{x:Type viewmodels:DashboardViewModel}">
                                    <views:DashboardView />
                                </DataTemplate>
                                <DataTemplate DataType="{x:Type viewmodels:MyGamesViewModel}">
                                    <views:MyGamesView />
                                </DataTemplate>
                                <DataTemplate DataType="{x:Type viewmodels:SettingsViewModel}">
                                    <views:SettingsView />
                                </DataTemplate>
                                <DataTemplate DataType="{x:Type viewmodels:DiscoverViewModel}">
                                    <views:DiscoverView />
                                </DataTemplate>
                                <DataTemplate DataType="{x:Type viewmodels:OnlineViewModel}">
                                    <views:OnlineView />
                                </DataTemplate>
                            </ContentControl.Resources>
                        </ContentControl>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Grid>
    </Grid>
</Window>
