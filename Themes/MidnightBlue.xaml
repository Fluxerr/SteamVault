<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ Color Palette — Midnight Blue ═══ -->
    <Color x:Key="WindowBackgroundColor">#0A0E27</Color>
    <Color x:Key="SidebarBackgroundColor">#0C1033</Color>
    <Color x:Key="CardBackgroundColor">#111740</Color>
    <Color x:Key="CardHoverColor">#1A2158</Color>
    <Color x:Key="PrimaryAccentColor">#00D4FF</Color>
    <Color x:Key="PrimaryAccentHoverColor">#33DDFF</Color>
    <Color x:Key="PrimaryAccentDarkColor">#0099CC</Color>
    <Color x:Key="PrimaryAccentGlowColor">#66EEFF</Color>
    <Color x:Key="SecondaryAccentColor">#FF6EC7</Color>
    <Color x:Key="SuccessColor">#00FFAA</Color>
    <Color x:Key="SuccessDarkColor">#00DD88</Color>
    <Color x:Key="WarningColor">#FFB84D</Color>
    <Color x:Key="ErrorColor">#FF4D6A</Color>
    <Color x:Key="TextColor">#E8ECFF</Color>
    <Color x:Key="MutedTextColor">#8E96CC</Color>
    <Color x:Key="DimTextColor">#5A6088</Color>
    <Color x:Key="BorderColor">#1E2550</Color>
    <Color x:Key="InputBackgroundColor">#0D1138</Color>
    <Color x:Key="SidebarActiveColor">#182060</Color>

    <SolidColorBrush x:Key="WindowBackground" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="SidebarBackground" Color="{StaticResource SidebarBackgroundColor}" />
    <SolidColorBrush x:Key="CardBackground" Color="{StaticResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="CardHover" Color="{StaticResource CardHoverColor}" />
    <SolidColorBrush x:Key="PrimaryAccent" Color="{StaticResource PrimaryAccentColor}" />
    <SolidColorBrush x:Key="PrimaryAccentHover" Color="{StaticResource PrimaryAccentHoverColor}" />
    <SolidColorBrush x:Key="PrimaryAccentDark" Color="{StaticResource PrimaryAccentDarkColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="SuccessDarkBrush" Color="{StaticResource SuccessDarkColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="Text" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="MutedText" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="DimText" Color="{StaticResource DimTextColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="InputBackground" Color="{StaticResource InputBackgroundColor}" />

    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#00D4FF" Offset="0"/>
        <GradientStop Color="#FF6EC7" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0C1033" Offset="0"/>
        <GradientStop Color="#0A0E27" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CardGlowBorder" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1E2550" Offset="0"/>
        <GradientStop Color="#003366" Offset="0.5"/>
        <GradientStop Color="#1E2550" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>