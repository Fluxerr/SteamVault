<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ Color Palette — Slate Gray ═══ -->
    <Color x:Key="WindowBackgroundColor">#151A22</Color>
    <Color x:Key="SidebarBackgroundColor">#1A1F28</Color>
    <Color x:Key="CardBackgroundColor">#1E2430</Color>
    <Color x:Key="CardHoverColor">#262D3A</Color>
    <Color x:Key="PrimaryAccentColor">#6C8EEF</Color>
    <Color x:Key="PrimaryAccentHoverColor">#8CA8FF</Color>
    <Color x:Key="PrimaryAccentDarkColor">#4A6DCC</Color>
    <Color x:Key="PrimaryAccentGlowColor">#AAC0FF</Color>
    <Color x:Key="SecondaryAccentColor">#8B9DC3</Color>
    <Color x:Key="SuccessColor">#4CAF50</Color>
    <Color x:Key="SuccessDarkColor">#388E3C</Color>
    <Color x:Key="WarningColor">#FFA726</Color>
    <Color x:Key="ErrorColor">#E53935</Color>
    <Color x:Key="TextColor">#E0E6F0</Color>
    <Color x:Key="MutedTextColor">#99A5B8</Color>
    <Color x:Key="DimTextColor">#6B7588</Color>
    <Color x:Key="BorderColor">#2A303C</Color>
    <Color x:Key="InputBackgroundColor">#181D26</Color>
    <Color x:Key="SidebarActiveColor">#242B38</Color>

    <SolidColorBrush x:Key="WindowBackground" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="SidebarBackground" Color="{StaticResource SidebarBackgroundColor}" />
    <SolidColorBrush x:Key="CardBackground" Color="{StaticResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="CardHover" Color="{StaticResource CardHoverColor}" />
    <SolidColorBrush x:Key="PrimaryAccent" Color="{StaticResource PrimaryAccentColor}" />
    <SolidColorBrush x:Key="PrimaryAccentHover" Color="{StaticResource PrimaryAccentHoverColor}" />
    <SolidColorBrush x:Key="PrimaryAccentDark" Color="{StaticResource PrimaryAccentDarkColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="SuccessDarkBrush" Color="{StaticResource SuccessDarkColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="Text" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="MutedText" Color="{StaticResource MutedTextColor}" />
    <SolidColorBrush x:Key="DimText" Color="{StaticResource DimTextColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="InputBackground" Color="{StaticResource InputBackgroundColor}" />

    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#6C8EEF" Offset="0"/>
        <GradientStop Color="#8B9DC3" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1A1F28" Offset="0"/>
        <GradientStop Color="#151A22" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CardGlowBorder" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#2A303C" Offset="0"/>
        <GradientStop Color="#3A4A66" Offset="0.5"/>
        <GradientStop Color="#2A303C" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>