<UserControl x:Class="SteamVault.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:SteamVault.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:DashboardViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="680" d:DesignWidth="860">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="36,28,36,36">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Title -->
                <RowDefinition Height="Auto"/>  <!-- Input + Download -->
                <RowDefinition Height="Auto"/>  <!-- Game Card (after download) -->
                <RowDefinition Height="Auto"/>  <!-- Status -->
            </Grid.RowDefinitions>

            <!-- ═══ Title ═══ -->
            <StackPanel Grid.Row="0" Margin="0,0,0,4">
                <TextBlock Text="SteamVault" Style="{StaticResource TitleText}"/>
                <TextBlock Text="Enter a Steam App ID and press Download. Everything is automatic." 
                           Style="{StaticResource SubtitleText}" Margin="0,-12,0,24"/>
            </StackPanel>

            <!-- ═══ Search + Download (single bar) ═══ -->
            <Border Grid.Row="1" Background="{StaticResource CardBackground}" CornerRadius="12" 
                    Padding="20,16" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Text="{Binding AppIdInput, UpdateSourceTrigger=PropertyChanged}" 
                             Height="48" FontSize="16" VerticalContentAlignment="Center"
                             Tag="Steam App ID (e.g. 730, 1245620, 292030)">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding DownloadCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Grid.Column="1" Content="⬇  Download" Width="160" Height="48" Margin="12,0,0,0" 
                            Command="{Binding DownloadCommand}"
                            Style="{StaticResource SuccessButton}" FontSize="15"/>
                </Grid>
            </Border>

            <!-- ═══ Game Result Card (shown after successful download) ═══ -->
            <Border Grid.Row="2" Background="{StaticResource CardBackground}" CornerRadius="12" 
                    Padding="0" Margin="0,0,0,16"
                    Visibility="{Binding HasGameInfo, Converter={StaticResource BoolToVis}}">
                <Grid Margin="24,24,24,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Game Image with rounded corners -->
                    <Border Grid.Column="0" CornerRadius="8" ClipToBounds="True" 
                            VerticalAlignment="Top" HorizontalAlignment="Left">
                        <Image Source="{Binding GameImage}" 
                               Stretch="Uniform" Width="260"/>
                    </Border>

                    <!-- Game Info -->
                    <StackPanel Grid.Column="1" Margin="24,0,0,0">
                        <TextBlock Text="{Binding GameName}" FontSize="24" FontWeight="Bold" 
                                   TextWrapping="Wrap" Margin="0,0,0,6"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="#252538" CornerRadius="4" Padding="8,3" Margin="0,0,8,0">
                                <TextBlock Text="{Binding AppIdInput, StringFormat='ID: {0}'}" 
                                           FontSize="12" Foreground="{StaticResource MutedText}"/>
                            </Border>
                            <Border Background="#252538" CornerRadius="4" Padding="8,3" Margin="0,0,8,0">
                                <TextBlock Text="{Binding GameType}" 
                                           FontSize="12" Foreground="{StaticResource MutedText}"/>
                            </Border>
                            <Border Background="#252538" CornerRadius="4" Padding="8,3">
                                <TextBlock Text="{Binding GameReleaseDate}" 
                                           FontSize="12" Foreground="{StaticResource MutedText}"/>
                            </Border>
                        </StackPanel>

                        <TextBlock Text="{Binding GameDescription}" 
                                   TextWrapping="Wrap" FontSize="13" 
                                   Foreground="{StaticResource MutedText}" 
                                   MaxHeight="60" TextTrimming="CharacterEllipsis"
                                   Margin="0,0,0,12"/>

                        <!-- Result Summary -->
                        <Border Background="#1A2A1A" CornerRadius="6" Padding="12,8" Margin="0,0,0,8">
                            <TextBlock Text="{Binding ResultSummary}" 
                                       Foreground="#4ADE80" FontSize="13" FontWeight="SemiBold"/>
                        </Border>

                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal">
                            <Button Content="▶  Install / Play in Steam" 
                                    Command="{Binding InstallGameCommand}"
                                    Style="{StaticResource SuccessButton}"
                                    HorizontalAlignment="Left" Padding="12,6" Margin="0,0,12,0"/>
                            <Button Content="📁  Open Lua Folder" 
                                    Command="{Binding OpenLuaFolderCommand}"
                                    Style="{StaticResource GhostButton}"
                                    HorizontalAlignment="Left" Padding="12,6"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ Status Bar ═══ -->
            <Border Grid.Row="3" Background="{StaticResource CardBackground}" CornerRadius="10" 
                    Padding="20,14" Margin="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Status Text -->
                    <TextBlock Grid.Row="0" Text="{Binding StatusMessage}" 
                               TextWrapping="Wrap" FontSize="13">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="Foreground" Value="{StaticResource MutedText}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasError}" Value="True">
                                        <Setter Property="Foreground" Value="#EF4444"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsComplete}" Value="True">
                                        <Setter Property="Foreground" Value="#4ADE80"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Progress Bar (only visible when downloading) -->
                    <ProgressBar Grid.Row="1" Value="{Binding Progress}" Maximum="100" 
                                 Height="6" Margin="0,12,0,0"
                                 Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}"/>

                    <!-- Success Banner -->
                    <Border Grid.Row="2" CornerRadius="8" Padding="16,12" Margin="0,14,0,0"
                            Visibility="{Binding IsComplete, Converter={StaticResource BoolToVis}}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#0D2818" Offset="0"/>
                                <GradientStop Color="#143A1B" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="✓" Foreground="#22C55E" FontSize="20" FontWeight="Bold" 
                                       Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="LUA GENERATED — READY TO USE" 
                                       Foreground="#4ADE80" FontSize="14" FontWeight="Bold" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Error Banner -->
                    <Border Grid.Row="3" CornerRadius="8" Padding="16,12" Margin="0,14,0,0"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#2A0D0D" Offset="0"/>
                                <GradientStop Color="#3A1414" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="✗" Foreground="#EF4444" FontSize="20" FontWeight="Bold" 
                                       Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="DOWNLOAD FAILED — CHECK APP ID" 
                                       Foreground="#F87171" FontSize="14" FontWeight="Bold" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
