<UserControl x:Class="SteamVault.Views.DiscoverView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:SteamVault.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:DiscoverViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="680" d:DesignWidth="860">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="40,32,40,40">
            <!-- ═══ BROWSE GRID ═══ -->
            <StackPanel Visibility="{Binding ShowBrowseGrid, Converter={StaticResource BoolToVis}}">
                <!-- Header -->
                <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                    <StackPanel>
                        <TextBlock Text="Discover" Style="{StaticResource TitleText}"/>
                        <TextBlock Text="Browse trending games, top sellers, and new releases from Steam." 
                                   Style="{StaticResource SubtitleText}" Margin="0,-12,0,0"/>
                    </StackPanel>
                    <Button Content="🔄  Refresh" Command="{Binding RefreshCommand}" 
                            Width="120" Height="40" HorizontalAlignment="Right" Margin="0,0,0,0"
                            VerticalAlignment="Top"/>
                </StackPanel>

                <!-- Status message -->
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource DimText}" 
                           FontSize="12" Margin="0,0,0,16"/>

                        <!-- Loading Shimmer -->
                        <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                            <ContentControl Style="{StaticResource ShimmerPlaceholder}" Height="200" Margin="0,0,0,16"/>
                            <ContentControl Style="{StaticResource ShimmerPlaceholder}" Height="200" Margin="0,0,0,16"/>
                        </StackPanel>

                        <!-- Trending -->
                        <TextBlock Text="🔥  Trending &amp; Featured" FontWeight="Bold" FontSize="18" Margin="0,0,0,16"
                                   Visibility="{Binding TrendingGames.Count, Converter={StaticResource BoolToVis}}"/>
                        <ItemsControl ItemsSource="{Binding TrendingGames}" Margin="0,0,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="DiscoverCard" Margin="6" 
                                            Background="{StaticResource CardBackground}" 
                                            CornerRadius="14" Padding="0" Cursor="Hand"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                            MouseLeftButtonDown="DiscoverCard_Click">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="110"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Border Grid.Row="0" CornerRadius="13,13,0,0" ClipToBounds="True">
                                                <Image Source="{Binding ImageUrl}" 
                                                       Stretch="UniformToFill" 
                                                       HorizontalAlignment="Center"
                                                       Style="{StaticResource FadeInImage}"/>
                                            </Border>
                                            <StackPanel Grid.Row="1" Margin="14,12,14,14">
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                                                <Border Background="#1E1E30" CornerRadius="6" Padding="8,3"
                                                        HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding AppId, StringFormat='ID: {0}'}" 
                                                               FontSize="11" Foreground="{StaticResource DimText}"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <Trigger SourceName="DiscoverCard" Property="IsMouseOver" Value="True">
                                            <Setter TargetName="DiscoverCard" Property="BorderBrush" Value="{StaticResource PrimaryAccent}"/>
                                            <Setter TargetName="DiscoverCard" Property="Background" Value="{StaticResource CardHover}"/>
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Top Sellers -->
                        <TextBlock Text="🏆  Top Sellers" FontWeight="Bold" FontSize="18" Margin="0,24,0,16"
                                   Visibility="{Binding TopSellers.Count, Converter={StaticResource BoolToVis}}"/>
                        <ItemsControl ItemsSource="{Binding TopSellers}" Margin="0,0,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="DiscoverCard" Margin="6" 
                                            Background="{StaticResource CardBackground}" 
                                            CornerRadius="14" Padding="0" Cursor="Hand"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                            MouseLeftButtonDown="DiscoverCard_Click">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="110"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Border Grid.Row="0" CornerRadius="13,13,0,0" ClipToBounds="True">
                                                <Image Source="{Binding ImageUrl}" 
                                                       Stretch="UniformToFill" 
                                                       HorizontalAlignment="Center"
                                                       Style="{StaticResource FadeInImage}"/>
                                            </Border>
                                            <StackPanel Grid.Row="1" Margin="14,12,14,14">
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                                                <Border Background="#1E1E30" CornerRadius="6" Padding="8,3"
                                                        HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding AppId, StringFormat='ID: {0}'}" 
                                                               FontSize="11" Foreground="{StaticResource DimText}"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <Trigger SourceName="DiscoverCard" Property="IsMouseOver" Value="True">
                                            <Setter TargetName="DiscoverCard" Property="BorderBrush" Value="{StaticResource PrimaryAccent}"/>
                                            <Setter TargetName="DiscoverCard" Property="Background" Value="{StaticResource CardHover}"/>
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- New Releases -->
                        <TextBlock Text="🆕  New Releases" FontWeight="Bold" FontSize="18" Margin="0,24,0,16"
                                   Visibility="{Binding NewReleases.Count, Converter={StaticResource BoolToVis}}"/>
                        <ItemsControl ItemsSource="{Binding NewReleases}" Margin="0,0,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="DiscoverCard" Margin="6" 
                                            Background="{StaticResource CardBackground}" 
                                            CornerRadius="14" Padding="0" Cursor="Hand"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                            MouseLeftButtonDown="DiscoverCard_Click">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="110"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Border Grid.Row="0" CornerRadius="13,13,0,0" ClipToBounds="True">
                                                <Image Source="{Binding ImageUrl}" 
                                                       Stretch="UniformToFill" 
                                                       HorizontalAlignment="Center"
                                                       Style="{StaticResource FadeInImage}"/>
                                            </Border>
                                            <StackPanel Grid.Row="1" Margin="14,12,14,14">
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                                                <Border Background="#1E1E30" CornerRadius="6" Padding="8,3"
                                                        HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding AppId, StringFormat='ID: {0}'}" 
                                                               FontSize="11" Foreground="{StaticResource DimText}"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <Trigger SourceName="DiscoverCard" Property="IsMouseOver" Value="True">
                                            <Setter TargetName="DiscoverCard" Property="BorderBrush" Value="{StaticResource PrimaryAccent}"/>
                                            <Setter TargetName="DiscoverCard" Property="Background" Value="{StaticResource CardHover}"/>
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Free to Play -->
                        <TextBlock Text="🎁  Free to Play" FontWeight="Bold" FontSize="18" Margin="0,24,0,16"
                                   Visibility="{Binding FreeGames.Count, Converter={StaticResource BoolToVis}}"/>
                        <ItemsControl ItemsSource="{Binding FreeGames}" Margin="0,0,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="DiscoverCard" Margin="6" 
                                            Background="{StaticResource CardBackground}" 
                                            CornerRadius="14" Padding="0" Cursor="Hand"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                            MouseLeftButtonDown="DiscoverCard_Click">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="110"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Border Grid.Row="0" CornerRadius="13,13,0,0" ClipToBounds="True">
                                                <Image Source="{Binding ImageUrl}" 
                                                       Stretch="UniformToFill" 
                                                       HorizontalAlignment="Center"
                                                       Style="{StaticResource FadeInImage}"/>
                                            </Border>
                                            <StackPanel Grid.Row="1" Margin="14,12,14,14">
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                                                <Border Background="#1E1E30" CornerRadius="6" Padding="8,3"
                                                        HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding AppId, StringFormat='ID: {0}'}" 
                                                               FontSize="11" Foreground="{StaticResource DimText}"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <Trigger SourceName="DiscoverCard" Property="IsMouseOver" Value="True">
                                            <Setter TargetName="DiscoverCard" Property="BorderBrush" Value="{StaticResource PrimaryAccent}"/>
                                            <Setter TargetName="DiscoverCard" Property="Background" Value="{StaticResource CardHover}"/>
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
            </StackPanel>

            <!-- ═══ GAME DETAIL VIEW ═══ -->
            <Border Visibility="{Binding ShowGameDetail, Converter={StaticResource BoolToVis}}"
                    Background="{StaticResource CardBackground}" CornerRadius="14" Padding="28"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Game Image -->
                    <Border Grid.Column="0" CornerRadius="10" ClipToBounds="True" VerticalAlignment="Top">
                        <Image Source="{Binding DetailGameImage}" Stretch="Uniform" Width="280"
                               Style="{StaticResource FadeInImage}"/>
                    </Border>

                    <!-- Detail Info -->
                    <StackPanel Grid.Column="1" Margin="28,0,0,0">
                        <!-- Back button -->
                        <Button Content="←  Back to Browse" Command="{Binding BackToDiscoverCommand}"
                                Style="{StaticResource GhostButton}" HorizontalAlignment="Left"
                                Padding="14,8" Margin="0,0,0,16" FontSize="12"/>

                        <TextBlock Text="{Binding DetailGameName}" FontSize="24" FontWeight="Bold" 
                                   TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <!-- Multiplayer Warning (with pulsing amber orb) -->
                        <Border CornerRadius="6" Padding="10,5" Margin="0,0,0,10"
                                BorderBrush="#8B5A00" BorderThickness="1"
                                Visibility="{Binding DetailShowMultiplayerWarning, Converter={StaticResource BoolToVis}}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1A1500" Offset="0"/>
                                    <GradientStop Color="#221800" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Style="{StaticResource PulsingDotAmber}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="SINGLEPLAYER ONLY — Multiplayer features unavailable in cracked copies" 
                                           Foreground="#FFB84D" FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Badges Row -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="#1E1E30" CornerRadius="6" Padding="10,4" Margin="0,0,8,0">
                                <TextBlock Text="{Binding DetailAppId, StringFormat='ID: {0}'}" 
                                           FontSize="12" Foreground="{StaticResource MutedText}"/>
                            </Border>
                            <Border Background="#1E1E30" CornerRadius="6" Padding="10,4" Margin="0,0,8,0">
                                <TextBlock Text="{Binding DetailType}" FontSize="12" Foreground="{StaticResource MutedText}"/>
                            </Border>
                            <Border Background="#1E1E30" CornerRadius="6" Padding="10,4">
                                <TextBlock Text="{Binding DetailReleaseDate}" FontSize="12" Foreground="{StaticResource MutedText}"/>
                            </Border>
                        </StackPanel>

                        <!-- Description -->
                        <TextBlock Text="{Binding DetailDescription}" TextWrapping="Wrap" FontSize="13" 
                                   Foreground="{StaticResource MutedText}" MaxHeight="60" 
                                   TextTrimming="CharacterEllipsis" Margin="0,0,0,12"/>

                        <!-- SteamDB Stats -->
                        <StackPanel Margin="0,0,0,14" Visibility="{Binding DetailHasStats, Converter={StaticResource BoolToVis}}">
                            <Border CornerRadius="6" Padding="10,6" Margin="0,0,0,4"
                                    Background="#1A1A2E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Style="{StaticResource PulsingDotGreen}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding DetailPlayerCount}" FontSize="12" Foreground="{StaticResource MutedText}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="6" Padding="10,6"
                                    Background="#1A1A2E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⭐" FontSize="12" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding DetailReviewScore}" FontSize="12" Foreground="{StaticResource MutedText}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Status + Progress -->
                        <Border CornerRadius="8" Padding="14,10" Margin="0,0,0,14">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#141420"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDownloadComplete}" Value="True">
                                            <Setter Property="BorderBrush" Value="#1A5A30"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Style="{StaticResource PulsingDot}" 
                                             Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}"
                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding DetailStatusMessage}" TextWrapping="Wrap" FontSize="13"
                                               Foreground="{StaticResource MutedText}"/>
                                </StackPanel>
                                <ProgressBar Value="{Binding DetailProgress}" Maximum="100" Height="6" Margin="0,12,0,0"
                                             Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </Border>

                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal">
                            <Button Content="⬇  Download" 
                                    Command="{Binding DownloadDetailGameCommand}"
                                    HorizontalAlignment="Left" Padding="18,10" Margin="0,0,12,0"/>
                            <Button Content="▶  Install via Steam" 
                                    Command="{Binding InstallDetailGameCommand}"
                                    Style="{StaticResource GhostButton}"
                                    HorizontalAlignment="Left" Padding="18,10"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>