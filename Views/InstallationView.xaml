<UserControl x:Class="SteamVault.Views.InstallationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:SteamVault.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>
        <converters:InvertibleBoolToVisibilityConverter x:Key="InvertBoolConverter"/>
        <converters:InvertibleBoolToVisibilityConverter x:Key="InvertBoolConverter2"/>
    </UserControl.Resources>
    
    <Grid>
        <!-- Main Installation Content (hidden when complete) -->
        <Grid Visibility="{Binding ShowInstallContent, Converter={StaticResource InvertBoolConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Center content -->
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="640" Margin="80,60,80,40">

                    <!-- Header -->
                    <StackPanel Margin="0,0,0,40">
                        <TextBlock Text="Welcome to SteamVault" FontSize="32" FontWeight="Bold" 
                                   Foreground="{StaticResource Text}" Margin="0,0,0,8"/>
                        <TextBlock Text="Before you begin, we need to set up OpenSteamTool in your Steam directory."
                                   FontSize="15" Foreground="{StaticResource MutedText}" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- What is this card -->
                    <Border Background="{StaticResource CardBackground}" CornerRadius="14" Padding="24" Margin="0,0,0,28"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="What is OpenSteamTool?" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                            <TextBlock Text="OpenSteamTool is a lightweight DLL plugin that sits inside your Steam directory. "
                                       FontSize="13" Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <TextBlock FontSize="13" Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,8">
                                <TextBlock.Text><![CDATA[It allows SteamVault to download and manage game manifests & Lua configurations]]></TextBlock.Text>
                            </TextBlock>
                            <TextBlock Text="3 lightweight DLL files (dwmapi.dll, OpenSteamTool.dll, xinput1_4.dll) placed directly into your Steam install folder. No other files are modified." 
                                       FontSize="13" Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,16"/>
                        </StackPanel>
                    </Border>

                    <!-- Steam Directory Card -->
                    <Border Background="{StaticResource CardBackground}" CornerRadius="14" Padding="28"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="Your Steam Directory" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                            <TextBlock Text="Detected from your system. If this is incorrect, use the folder icon to browse."
                                       FontSize="13" Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                            <!-- Directory input row -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="{StaticResource InputBackground}" CornerRadius="10"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        Height="44" Margin="0,0,8,0">
                                    <Grid Margin="14,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="📂" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SteamDirectory}"
                                                   Foreground="{StaticResource Text}" FontSize="13"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Border>

                                <Button Grid.Column="1" Command="{Binding BrowseCommand}" 
                                        Width="44" Height="44" VerticalAlignment="Center"
                                        Style="{StaticResource GhostButton}" Padding="0"
                                        IsEnabled="{Binding CanBrowse}">
                                    <TextBlock Text="📁" FontSize="18"/>
                                </Button>
                            </Grid>

                            <!-- Status line -->
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <TextBlock Text="{Binding StatusIcon}" FontSize="14" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding StatusMessage}" FontSize="12" 
                                           Foreground="{StaticResource MutedText}" VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Installation details card -->
                    <Border Background="{StaticResource CardBackground}" CornerRadius="14" Padding="24"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,28">
                        <StackPanel>
                            <TextBlock Text="What will be installed" FontWeight="Bold" FontSize="14" Margin="0,0,0,12"/>

                            <!-- DLLs -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource PrimaryAccent}"
                                        VerticalAlignment="Top" Margin="0,6,12,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="OpenSteamTool DLLs" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="3 DLL files copied to your Steam directory" FontSize="12"
                                               Foreground="{StaticResource DimText}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>

                            <!-- Lua folder -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource SuccessBrush}"
                                        Margin="0,6,12,0" VerticalAlignment="Top"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Lua Config Directory" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{Binding SteamDirectory, StringFormat='{}{0}\\config\\lua'}" FontSize="12"
                                               Foreground="{StaticResource DimText}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>

                            <!-- Manifest cache folder -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                        <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource PrimaryAccent}"
                                        Margin="0,6,12,0" VerticalAlignment="Top"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Manifest Cache Directory" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{Binding SteamDirectory, StringFormat='{}{0}\\config\\depotcache'}" FontSize="12"
                                               Foreground="{StaticResource DimText}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Admin prompt -->
                    <Border Background="#1A1A20" CornerRadius="14" Padding="24"
                            BorderBrush="{StaticResource WarningBrush}" BorderThickness="1"
                            Visibility="{Binding ShowAdminPrompt, Converter={StaticResource InvertBoolConverter2}}"
                            Margin="0,0,0,24">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔒" FontSize="20" Margin="0,0,12,0" VerticalAlignment="Top"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Administrator Access Required" FontWeight="Bold" FontSize="15" Margin="0,0,0,4"/>
                                    <TextBlock Text="SteamVault needs administrator permissions to create the necessary folders in your Steam directory. This is a one-time requirement." 
                                               FontSize="13" Foreground="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,16"/>
                                    <Button Content="🔓  Restart as Administrator" Command="{Binding RetryAsAdminCommand}"
                                            Width="220" Height="40" Style="{StaticResource SuccessButton}"
                                            HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Bottom confirmation bar -->
            <Border Grid.Row="1" Background="#0E0E18" Padding="24,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Installing indicator + progress -->
                    <StackPanel Visibility="{Binding IsInstalling, Converter={StaticResource InvertBoolConverter}}"
                                VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource PrimaryAccent}" Margin="0,0,8,0"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="0.3" To="1" Duration="0:0:0.8"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                 From="0.7" To="1.2" Duration="0:0:0.8"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                 From="0.7" To="1.2" Duration="0:0:0.8"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock Text="{Binding ProgressText}" FontSize="13" Foreground="{StaticResource MutedText}"/>
                        </StackPanel>
                        <ProgressBar Value="{Binding ProgressPercent}" Width="200" Height="6" 
                                     IsIndeterminate="False" Minimum="0" Maximum="100"/>
                    </StackPanel>

                    <TextBlock Grid.Column="0" Text="Ready to install — confirm to proceed." 
                               FontSize="13" Foreground="{StaticResource DimText}" VerticalAlignment="Center"
                               Visibility="{Binding IsInstalling, Converter={StaticResource InvertBoolConverter2}, ConverterParameter=invert}"/>

                    <Button Grid.Column="1" Content="Install OpenSteamTool" 
                            Command="{Binding ConfirmCommand}"
                            IsEnabled="{Binding CanConfirm}"
                            Width="220" Height="44" Style="{StaticResource SuccessButton}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Installation Complete (fade overlay) -->
        <Grid Visibility="{Binding IsComplete, Converter={StaticResource InvertBoolConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="80" Height="80" CornerRadius="40" Margin="0,0,0,24"
                        HorizontalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#059669" Offset="0"/>
                            <GradientStop Color="#10B981" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="✓" FontSize="40" Foreground="White" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="All Set!" FontSize="28" FontWeight="Bold" Foreground="{StaticResource Text}"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="15" Foreground="{StaticResource MutedText}"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Entering SteamVault..." FontSize="14" Foreground="{StaticResource DimText}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>