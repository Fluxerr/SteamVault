<UserControl x:Class="SteamVault.Views.MyGamesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:SteamVault.ViewModels"
             xmlns:converters="clr-namespace:SteamVault.Converters"
             d:DataContext="{d:DesignInstance Type=viewmodels:MyGamesViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="680" d:DesignWidth="860">
    <UserControl.Resources>
        <converters:InvertibleBoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:StringEqualityToVisibilityConverter x:Key="StringEqualsToVis" />

        <!-- Up to Date Pill Button -->
        <Style x:Key="UpToDateButton" TargetType="Button">
            <Setter Property="Background" Value="#102A1A" />
            <Setter Property="Foreground" Value="#10B981" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#0A5A30"/>
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="IsEnabled" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="40,32,40,40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="Auto"/>  <!-- Search & Toolbar -->
                <RowDefinition Height="*"/>     <!-- Games Grid -->
                <RowDefinition Height="Auto"/>  <!-- Batch progress -->
            </Grid.RowDefinitions>

            <!-- ═══ Header ═══ -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="My Games" Style="{StaticResource TitleText}"/>
                <TextBlock Text="Scan and manage your local Lua vault. Batch check or update manifests with a single click." 
                           Style="{StaticResource SubtitleText}" Margin="0,-12,0,12"/>
            </StackPanel>

            <!-- ═══ Search & Action Toolbar ═══ -->
            <Grid Grid.Row="1" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                         Height="42" FontSize="14" VerticalContentAlignment="Center"
                         Tag="🔍  Filter local games by name or App ID..."/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                    <Button Content="🔄  Refresh" 
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource GhostButton}" 
                            Width="120" Height="42" Margin="0,0,8,0"/>

                    <Button Content="⚡  Update All" 
                            Command="{Binding UpdateAllCommand}"
                            Width="140" Height="42"/>
                </StackPanel>
            </Grid>

            <!-- ═══ No Games Placeholder ═══ -->
            <Border Grid.Row="2" 
                    Background="{StaticResource CardBackground}" 
                    CornerRadius="14" Padding="48,80"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    Visibility="{Binding HasNoGames, Converter={StaticResource BoolToVis}}"
                    HorizontalAlignment="Stretch" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="📂" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock Text="No Games Found in Vault" FontSize="20" FontWeight="Bold" 
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Your Steam config/lua directory appears to be empty. Search and download some game manifests on the Dashboard first!" 
                               Foreground="{StaticResource MutedText}" FontSize="13" 
                               TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"
                               MaxWidth="420"/>
                </StackPanel>
            </Border>

            <!-- ═══ Games Grid ═══ -->
            <Grid Grid.Row="2" 
                  Visibility="{Binding HasNoGames, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                <ItemsControl ItemsSource="{Binding Games}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Game Card with Hover Glow -->
                            <Border x:Name="GameCard" Margin="8" 
                                    Background="{StaticResource CardBackground}" 
                                    CornerRadius="14" Padding="0"
                                    BorderBrush="#1E1E30" BorderThickness="1"
                                    ToolTipService.ToolTip="{Binding Name}"
                                    ToolTipService.Placement="Mouse"
                                    ToolTipService.ShowDuration="5000">
                                <Border.Resources>
                                    <Style TargetType="ToolTip" BasedOn="{StaticResource PremiumToolTip}">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" 
                                                               Margin="0,0,0,4" Foreground="White"/>
                                                    <TextBlock FontSize="11" Foreground="{StaticResource MutedText}">
                                                        <Run Text="App ID:"/>
                                                        <Run Text="{Binding AppId}" Foreground="{StaticResource PrimaryAccent}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Status, StringFormat='Status: {0}'}" 
                                                               FontSize="11" Foreground="{StaticResource MutedText}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Border.Resources>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="130"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Game store image banner with fade-in -->
                                    <Border Grid.Row="0" CornerRadius="13,13,0,0" ClipToBounds="True">
                                        <Grid>
                                            <Image Source="{Binding HeaderImageUrl}" 
                                                   Stretch="UniformToFill" 
                                                   HorizontalAlignment="Center"
                                                   Style="{StaticResource FadeInImage}"/>
                                            <Border>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="Transparent" Offset="0.5"/>
                                                        <GradientStop Color="#CC0A0A14" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Game Details and Actions -->
                                    <StackPanel Grid.Row="1" Margin="18,14,18,18">
                                        <TextBlock Text="{Binding Name}" 
                                                   FontSize="17" FontWeight="Bold"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,0,8"/>

                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Background="#1A1A2E" CornerRadius="6" Padding="8,3">
                                                <TextBlock Text="{Binding AppId, StringFormat='App ID {0}'}" 
                                                           FontSize="11" Foreground="{StaticResource MutedText}"/>
                                            </Border>

                                            <Border Grid.Column="2" CornerRadius="6" Padding="10,3"
                                                    Background="{Binding StatusBrush, FallbackValue=#1A1A2E}">
                                                <TextBlock Text="{Binding Status}" 
                                                           FontSize="11" FontWeight="Bold"
                                                           Foreground="White"/>
                                            </Border>
                                        </Grid>

                                        <TextBlock Text="{Binding LastUpdated, StringFormat='Last generated: {0:g}'}" 
                                                   FontSize="11" Foreground="{StaticResource DimText}"
                                                   Margin="0,0,0,14"/>

                                        <ProgressBar Value="{Binding UpdateProgress}" Maximum="100" 
                                                     Height="5" Margin="0,0,0,12"
                                                     Visibility="{Binding IsUpdating, Converter={StaticResource BoolToVis}}"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Content="⬇  Update" 
                                                    Command="{Binding DataContext.UpdateGameCommand, 
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding CanUpdate, Converter={StaticResource BoolToVis}}"
                                                    HorizontalAlignment="Left"/>

                                            <Button Content="✓  Up to Date" 
                                                    Style="{StaticResource UpToDateButton}"
                                                    Visibility="{Binding Status, Converter={StaticResource StringEqualsToVis}, ConverterParameter=Up to Date}"
                                                    HorizontalAlignment="Left"/>

                                            <Button Grid.Column="1" Content="📁  Lua Folder" 
                                                    Command="{Binding DataContext.OpenGameFolderCommand, 
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource GhostButton}"
                                                    FontSize="11" Padding="12,6"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <Trigger SourceName="GameCard" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="GameCard" Property="BorderBrush" Value="#7C3AED"/>
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <!-- ═══ Footer Batch scan status with Pulsing Dot ═══ -->
            <Border Grid.Row="3" Background="{StaticResource CardBackground}" CornerRadius="12" 
                    Padding="16,14" Margin="0,16,0,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse x:Name="ScanDot" Width="8" Height="8" Margin="0,0,10,0" 
                             VerticalAlignment="Center" Visibility="Visible"
                             Style="{StaticResource PulsingDot}"/>
                    <TextBlock Text="{Binding StatusMessage}" 
                               Foreground="{StaticResource MutedText}" FontSize="13" 
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>