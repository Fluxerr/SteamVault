<UserControl x:Class="SteamVault.Views.OnlineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:SteamVault.ViewModels"
             xmlns:converters="clr-namespace:SteamVault.Converters"
             d:DataContext="{d:DesignInstance Type=viewmodels:OnlineViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="680" d:DesignWidth="860">
    <UserControl.Resources>
        <converters:InvertibleBoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="40,32,40,40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="Online" Style="{StaticResource TitleText}"/>
                <TextBlock Text="Apply multiplayer fixes from online-fix.me to your installed games." 
                           Style="{StaticResource SubtitleText}" Margin="0,-12,0,12"/>
            </StackPanel>

            <!-- Toolbar -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1" Content="Refresh" 
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource GhostButton}" 
                        Width="120" Height="42"/>
            </Grid>

            <!-- ==================== GAME GRID VIEW ==================== -->
            <Grid Grid.Row="2" Visibility="{Binding ShowGameGrid, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- No games state -->
                <TextBlock Grid.Row="0" Text="No online-capable games found in your library."
                           Visibility="{Binding HasNoGames, Converter={StaticResource BoolToVis}}"
                           Foreground="{StaticResource MutedText}" FontSize="15"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- Games Grid -->
                <ItemsControl ItemsSource="{Binding Games}" Grid.Row="0"
                              Visibility="{Binding HasNoGames, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="OnlineCard" Margin="8" 
                                    Background="{StaticResource CardBackground}" 
                                    CornerRadius="14" Padding="0"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding Gesture="LeftClick"
                                                  Command="{Binding DataContext.SelectGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="130"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Game header image -->
                                    <Border Grid.Row="0" CornerRadius="13,13,0,0" ClipToBounds="True">
                                        <Grid>
                                            <Image Source="{Binding HeaderImageUrl}" 
                                                   Stretch="UniformToFill" 
                                                   HorizontalAlignment="Center"
                                                   Style="{StaticResource FadeInImage}"/>
                                            <Border>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="Transparent" Offset="0.5"/>
                                                        <GradientStop Color="#CC0A0A14" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Details and status -->
                                    <StackPanel Grid.Row="1" Margin="18,14,18,18">
                                        <TextBlock Text="{Binding Name}" 
                                                   FontSize="17" FontWeight="Bold"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,0,8"/>

                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Background="#1E1E30" CornerRadius="6" Padding="8,3">
                                                <TextBlock Text="{Binding AppId, StringFormat='App ID {0}'}" 
                                                           FontSize="11" Foreground="{StaticResource MutedText}"/>
                                            </Border>

                                            <!-- Status Badge -->
                                            <Border Grid.Column="2" CornerRadius="6" Padding="10,3">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#2A1A0A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding FixApplied}" Value="True">
                                                                <Setter Property="Background" Value="#102A1A"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                                <Setter Property="Background" Value="#1A1A2E"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding FixApplied}" Value="True">
                                                                    <Setter Property="Foreground" Value="#10B981"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource PrimaryAccent}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </Grid>

                                        <!-- Card action buttons -->
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="View Details" 
                                                    Command="{Binding DataContext.SelectGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource GhostButton}"
                                                    FontSize="11" Padding="10,6"
                                                    ToolTip="View details"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <Trigger SourceName="OnlineCard" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="OnlineCard" Property="BorderBrush" Value="{StaticResource PrimaryAccent}"/>
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <!-- ==================== DETAIL VIEW ==================== -->
            <Grid Grid.Row="2" Visibility="{Binding ShowGameDetail, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Back button -->
                <Button Grid.Row="0" Content="← Back to Games" 
                        Command="{Binding BackToGridCommand}"
                        Style="{StaticResource GhostButton}"
                        HorizontalAlignment="Left" Margin="0,0,0,16"
                        FontSize="13" Padding="12,8"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Game header image + info -->
                        <StackPanel Grid.Column="0" Margin="0,0,24,0">
                            <Border CornerRadius="14" ClipToBounds="True" 
                                    Background="{StaticResource CardBackground}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <Image Source="{Binding SelectedGame.HeaderImageUrl}" 
                                       Stretch="UniformToFill" MinHeight="180"
                                       Style="{StaticResource FadeInImage}"/>
                            </Border>

                            <StackPanel Margin="0,20,0,0">
                                <TextBlock Text="{Binding SelectedGame.Name}" 
                                           FontSize="22" FontWeight="Bold"
                                           TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding SelectedGame.AppId, StringFormat='App ID: {0}'}"
                                           Foreground="{StaticResource MutedText}" FontSize="13"
                                           Margin="0,0,0,12"/>

                                <!-- Status Badge -->
                                <Border CornerRadius="8" Padding="14,8" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#2A1A0A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedGame.FixApplied}" Value="True">
                                                    <Setter Property="Background" Value="#102A1A"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedGame.IsInstalled}" Value="False">
                                                    <Setter Property="Background" Value="#2A1A0A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding SelectedGame.Status}" 
                                               FontSize="13" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#F59E0B"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedGame.FixApplied}" Value="True">
                                                        <Setter Property="Foreground" Value="#10B981"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <!-- Open game folder button -->
                                <Button Content="Open Game Folder" 
                                        Command="{Binding OpenGameDirCommand}"
                                        CommandParameter="{Binding SelectedGame}"
                                        Style="{StaticResource GhostButton}"
                                        HorizontalAlignment="Left" Margin="0,16,0,0"
                                        FontSize="12" Padding="12,8"
                                        Visibility="{Binding SelectedGame.IsInstalled, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Right: Instructions + URL + Download -->
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="How to apply a multiplayer fix:" 
                                       FontSize="17" FontWeight="Bold" 
                                       Margin="0,0,0,16"/>

                             <!-- Step-by-step instructions -->
                             <Border Background="{StaticResource CardBackground}" 
                                     CornerRadius="12" Padding="20,18"
                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                     Margin="0,0,0,20">
                                 <StackPanel>
                                     <TextBlock Text="1. Click the button below to open online-fix.me in your browser."
                                                Foreground="{StaticResource Text}" FontSize="13"
                                                TextWrapping="Wrap" Margin="0,0,0,8"/>
                                     <TextBlock Text="2. Search for your game on the website."
                                                Foreground="{StaticResource Text}" FontSize="13"
                                                TextWrapping="Wrap" Margin="0,0,0,8"/>
                                     <TextBlock Text="3. Click 'Download fix from the server' on the game page."
                                                Foreground="{StaticResource Text}" FontSize="13"
                                                TextWrapping="Wrap" Margin="0,0,0,8"/>
                                     <TextBlock Text="4. Select the 'Fix Repair' folder (top option)."
                                                Foreground="{StaticResource Text}" FontSize="13"
                                                TextWrapping="Wrap" Margin="0,0,0,8"/>
                                     <TextBlock Text="5. Download the .rar file."
                                                Foreground="{StaticResource Text}" FontSize="13"
                                                TextWrapping="Wrap" Margin="0,0,0,8"/>
                                     <TextBlock Text="6. Save it to the SteamVault app folder."
                                                Foreground="{StaticResource Text}" FontSize="13"
                                                TextWrapping="Wrap" Margin="0,0,0,8"/>
                                     <TextBlock Text="7. The app auto-detects and extracts it (password: online-fix.me)."
                                                Foreground="{StaticResource Text}" FontSize="13"
                                                TextWrapping="Wrap"/>
                                 </StackPanel>
                             </Border>

                            <!-- Open online-fix.me button -->
                            <Button Content="Open online-fix.me in Browser" 
                                    Command="{Binding OpenOnlineFixCommand}"
                                    CommandParameter="{Binding SelectedGame}"
                                    Height="42" Margin="0,0,0,16"
                                    FontSize="13" FontWeight="SemiBold"
                                    Foreground="White" Cursor="Hand"
                                    HorizontalAlignment="Stretch">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" CornerRadius="10" Background="#2A3A5E" Padding="20,10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#3A4A6E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>


                            <!-- Download progress -->
                            <ProgressBar Value="{Binding DownloadProgress}" Maximum="100" 
                                         Height="5" Margin="0,0,0,12"
                                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>

                             <!-- Apply Fix button -->
                             <Button Content="Apply Fix" 
                                     Command="{Binding ApplyFixCommand}"
                                     CommandParameter="{Binding SelectedGame}"
                                     Height="42"
                                     FontSize="13" FontWeight="Bold"
                                     Foreground="White" Cursor="Hand"
                                     HorizontalAlignment="Stretch"
                                     Visibility="{Binding SelectedGame.IsInstalled, Converter={StaticResource BoolToVis}}">
                                 <Button.Template>
                                     <ControlTemplate TargetType="Button">
                                         <Border x:Name="Bg" CornerRadius="10" Background="{StaticResource PrimaryAccent}" Padding="20,10">
                                             <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                         </Border>
                                         <ControlTemplate.Triggers>
                                             <Trigger Property="IsMouseOver" Value="True">
                                                 <Setter TargetName="Bg" Property="Background" Value="#7D5FFF"/>
                                             </Trigger>
                                         </ControlTemplate.Triggers>
                                     </ControlTemplate>
                                 </Button.Template>
                             </Button>

                             <!-- Run as Administrator button (appears when permission denied) -->
                             <Button Content="🔒 Restart as Administrator" 
                                     Command="{Binding RestartAsAdminCommand}"
                                     Height="42" Margin="0,12,0,0"
                                     FontSize="13" FontWeight="Bold"
                                     Foreground="White" Cursor="Hand"
                                     HorizontalAlignment="Stretch"
                                     Visibility="{Binding NeedsAdminRights, Converter={StaticResource BoolToVis}}">
                                 <Button.Template>
                                     <ControlTemplate TargetType="Button">
                                         <Border x:Name="Bg" CornerRadius="10" Background="#F59E0B" Padding="20,10">
                                             <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                         </Border>
                                         <ControlTemplate.Triggers>
                                             <Trigger Property="IsMouseOver" Value="True">
                                                 <Setter TargetName="Bg" Property="Background" Value="#D97706"/>
                                             </Trigger>
                                         </ControlTemplate.Triggers>
                                     </ControlTemplate>
                                 </Button.Template>
                             </Button>

                            <!-- Not installed message -->
                            <Border CornerRadius="10" Padding="16,14" Background="#2A1A0A"
                                    Visibility="{Binding SelectedGame.IsInstalled, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                <TextBlock Text="This game is not installed. Install it via Steam first, then come back to apply the fix."
                                           Foreground="#F59E0B" FontSize="13" TextWrapping="Wrap"/>
                            </Border>

                            <!-- Status message -->
                            <Border CornerRadius="10" Padding="16,14" 
                                    Background="{StaticResource CardBackground}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                    Margin="0,20,0,0">
                                <TextBlock Text="{Binding DetailStatusMessage}" 
                                           Foreground="{StaticResource MutedText}" FontSize="13" 
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- Footer Status -->
            <Border Grid.Row="3" Background="{StaticResource CardBackground}" CornerRadius="12" 
                    Padding="16,14" Margin="0,16,0,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse Style="{StaticResource PulsingDot}" 
                             VerticalAlignment="Center" Margin="0,0,10,0" Width="10" Height="10"/>
                    <TextBlock Text="{Binding StatusMessage}" 
                               Foreground="{StaticResource MutedText}" FontSize="13" 
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Status Bar (when not scanning) -->
            <Border Grid.Row="3" Background="{StaticResource CardBackground}" CornerRadius="12" 
                    Padding="16,14" Margin="0,16,0,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                <TextBlock Text="{Binding StatusMessage}" 
                           Foreground="{StaticResource MutedText}" FontSize="13" 
                           HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>